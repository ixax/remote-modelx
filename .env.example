# Optional. Comma-separated list of models to pull/warm into Ollama, e.g.
# "gemma3:4b,bge-m3" -- leave unset for a reranker-only deployment
# (ollama-pull skips it instead of failing). bge-m3 is a solid multilingual
# embedding model with strong Russian support (dense + lexical/sparse
# matching, not just semantic similarity).
OLLAMA_MODELS=

# Optional. Prompt `make smoketest` sends to each OLLAMA_MODELS entry in
# turn (manual, opt-in -- see README). Embedding-only models are expected
# to fail this (no chat template); that's the smoketest surfacing it, not
# a bug.
#MODEL_SMOKETEST_PROMPT=Hello, who are you?

# Optional. Host-published port for Ollama.
#OLLAMA_PORT=11434

# Optional. Cross-encoder model, pulled from Hugging Face on first request
# (not baked into the image), e.g. "BAAI/bge-reranker-v2-m3" -- leave
# unset if you don't need reranking (the reranker container logs why and
# exits instead of starting).
RERANKER_MODEL=

# Optional. Host-published port for the reranker.
#RERANKER_PORT=50051

# Optional, AMD/ROCm GPU deployments only (make up-gpu-amd /
# docker-compose.gpu-amd.yml). Overrides the gfx target ROCm reports the
# card as -- needed for cards not on ROCm's official support list (e.g.
# the RX 6800M / gfx1031, which runs via the gfx1030 build). Check your
# card's real target with `rocminfo | grep gfx` inside a ROCm container.
#HSA_OVERRIDE_GFX_VERSION=10.3.0

# Optional. One of Python logging's level names: DEBUG, INFO, WARNING,
# ERROR, CRITICAL. Applies to the reranker only (Ollama has its own logging).
#LOG_LEVEL=INFO
