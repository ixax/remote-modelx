# Optional. Comma-separated list of models to pull/warm into Ollama, e.g.
# "gemma3:4b,bge-m3" -- leave unset for a reranker-only deployment. bge-m3
# is a solid multilingual embedding model with strong Russian support
# (dense + lexical/sparse matching, not just semantic similarity).
#
# Read by the `ollama-pull`/`model-smoketest` Docker services
# (docker-compose.yml) on every path, including AMD -- `make up-amd`/
# `pull-host`/`smoketest-host` point those same containers at the host's
# native Ollama instead of the Docker one (see AGENTS.md).
OLLAMA_MODELS=

# Optional. Prompt `make smoketest`/`smoketest-host` sends to each
# OLLAMA_MODELS entry in turn. Manual/opt-in on every path -- gated behind
# Compose's `smoketest` profile, never runs as part of `make up`/
# `up-gpu-nvidia`/`up-amd`. Embedding-only models are expected to fail this
# (no chat template); that's the check surfacing it, not a bug.
#MODEL_SMOKETEST_PROMPT=Hello, who are you?

# Optional, CPU/NVIDIA deployments only -- ignored on the AMD path (Ollama
# isn't a Docker service there, see AGENTS.md). Host-published port for
# Ollama.
#OLLAMA_PORT=11434

# Optional. Cross-encoder model, pulled from Hugging Face at container
# startup (not baked into the image, loaded eagerly rather than on first
# request), e.g. "BAAI/bge-reranker-v2-m3" -- leave unset if you don't need
# reranking (the reranker container logs why and exits instead of
# starting).
RERANKER_MODEL=

# Optional. Host-published port for the reranker.
#RERANKER_PORT=50051

# Optional. One of Python logging's level names: DEBUG, INFO, WARNING,
# ERROR, CRITICAL. Applies to the reranker only (Ollama has its own logging).
#LOG_LEVEL=INFO
