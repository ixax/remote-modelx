# Optional. Comma-separated list of models to pull/warm into Ollama, e.g.
# "gemma3:4b,embeddinggemma:300m" -- leave unset for a reranker-only
# deployment (ollama-pull skips it instead of failing).
OLLAMA_MODELS=

# Optional. Prompt `make smoketest` sends to each OLLAMA_MODELS entry in
# turn (manual, opt-in -- see README). Embedding-only models are expected
# to fail this (no chat template); that's the smoketest surfacing it, not
# a bug.
#MODEL_SMOKETEST_PROMPT=Hello, who are you?

# Optional. Host-published port for Ollama.
#OLLAMA_PORT=11434

# Optional. Cross-encoder model, pulled from Hugging Face on first request
# (not baked into the image) -- leave unset if you don't need reranking
# (the reranker container logs why and exits instead of starting).
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Optional. Host-published port for the reranker.
#RERANKER_PORT=50051

# Optional, GPU deployments only (make up-gpu / docker-compose.gpu.yml).
# Overrides the default CUDA 12.1 torch wheel index for an older driver,
# e.g. https://download.pytorch.org/whl/cu118
#RERANKER_TORCH_INDEX_URL=

# Optional. One of Python logging's level names: DEBUG, INFO, WARNING,
# ERROR, CRITICAL. Applies to the reranker only (Ollama has its own logging).
#LOG_LEVEL=INFO
